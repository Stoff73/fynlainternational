{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/tax-hardcode-check.sh\"",
            "timeout": 15,
            "statusMessage": "Checking for hardcoded tax values..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/tax-hardcode-check.sh\"",
            "timeout": 15,
            "statusMessage": "Final tax-hardcode sweep..."
          }
        ]
      }
    ]
  }
}
