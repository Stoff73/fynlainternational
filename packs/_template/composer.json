{
    "name": "fynla/pack-country-xx",
    "type": "library",
    "description": "Fynla country pack — <Country>",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Fynla\\Packs\\XX\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Fynla\\Packs\\XX\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Fynla\\Packs\\XX\\Providers\\CountryPackServiceProvider"
            ]
        },
        "fynla": {
            "pack": {
                "code": "xx",
                "currency": "XXX",
                "locale": "en-XX",
                "table_prefix": "xx_"
            }
        }
    }
}
