{
    "name": "fynla/pack-country-za",
    "type": "library",
    "description": "Fynla South Africa country pack — SARS 2026/27 tax engine, Section 11F / Section 10C trackers, and za_tax_configurations schema.",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0",
        "illuminate/database": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Fynla\\Packs\\Za\\": "src/",
            "Fynla\\Packs\\Za\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Fynla\\Packs\\Za\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Fynla\\Packs\\Za\\Providers\\ZaPackServiceProvider"
            ]
        },
        "fynla": {
            "pack": {
                "code": "za",
                "currency": "ZAR",
                "locale": "en_ZA",
                "table_prefix": "za_"
            }
        }
    }
}
