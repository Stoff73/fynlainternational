# =============================================================================
# Fynla — fynla.org PRODUCTION environment
# =============================================================================
# This is the template for the PRODUCTION environment — the one running on
# fynla.org. Dev/staging config lives in deploy/csjones-fynla/.env.production
# and the .env on the csjones.co server.
#
# Upload:  copy to ~/www/fynla.org/public_html/.env on the server, then fill
#          in every YOUR_* placeholder with real credentials.
#
# Never commit real secrets to this file. The .env on the server is where
# the real values live. This template just documents the full variable set
# and the settings that distinguish production from dev.
# =============================================================================

APP_NAME="Fynla"
APP_ENV=production
APP_KEY=base64:GENERATE_THIS_ON_SERVER_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://fynla.org
APP_TIMEZONE=Europe/London

# =============================================================================
# Database — production DB on fynla.org (SiteGround Site Tools > MySQL)
# =============================================================================
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=YOUR_PRODUCTION_DATABASE_NAME
DB_USERNAME=YOUR_PRODUCTION_DATABASE_USERNAME
DB_PASSWORD=YOUR_PRODUCTION_DATABASE_PASSWORD

# =============================================================================
# Cache / Session / Queue
# =============================================================================
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
QUEUE_CONNECTION=sync
BROADCAST_DRIVER=log
FILESYSTEM_DISK=local

# =============================================================================
# Logging — keep quiet on production; only errors and warnings
# =============================================================================
LOG_CHANNEL=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# =============================================================================
# Mail — production SMTP via the fynla.org domain
# =============================================================================
MAIL_MAILER=smtp
MAIL_HOST=mail.fynla.org
MAIL_PORT=465
MAIL_USERNAME=noreply@fynla.org
MAIL_PASSWORD=YOUR_MAIL_PASSWORD
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="noreply@fynla.org"
MAIL_FROM_NAME="Fynla"

# =============================================================================
# Payment — Revolut PRODUCTION
# =============================================================================
# Production keys are live — they charge real cards. Never mix with sandbox.
PAYMENT_ENABLED=true
REVOLUT_SANDBOX=false
REVOLUT_API_KEY=YOUR_REVOLUT_PRODUCTION_SK
REVOLUT_PUBLIC_KEY=YOUR_REVOLUT_PRODUCTION_PK
REVOLUT_WEBHOOK_SECRET=YOUR_REVOLUT_PRODUCTION_WEBHOOK_WSK

# =============================================================================
# Lifecycle email engine
# =============================================================================
# Kill switch — set to false to disable the lifecycle engine without a file
# rollback. The lifecycle:run-daily command checks this first.
LIFECYCLE_ENGINE_ENABLED=true

# test_recipient_override must remain UNSET on production so the engine sends
# emails to each user's real address. Never set this on prod.
# LIFECYCLE_TEST_RECIPIENT=

# =============================================================================
# Frontend — must match root deployment
# =============================================================================
VITE_APP_NAME="Fynla"
VITE_API_BASE_URL=https://fynla.org
VITE_REVOLUT_PUBLIC_KEY="${REVOLUT_PUBLIC_KEY}"
VITE_REVOLUT_SANDBOX=false

# =============================================================================
# Sanctum — stateful session domains for API auth
# =============================================================================
SANCTUM_STATEFUL_DOMAINS=fynla.org,www.fynla.org

# =============================================================================
# Security
# =============================================================================
BCRYPT_ROUNDS=12

# =============================================================================
# AI
# =============================================================================
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6
ANTHROPIC_ADVANCED_CHAT_MODEL=claude-opus-4-6

# =============================================================================
# Internal agent token — rotate independently from dev
# =============================================================================
AGENT_INTERNAL_TOKEN=YOUR_PRODUCTION_AGENT_TOKEN

# =============================================================================
# Admin
# =============================================================================
ADMIN_EMAILS=chris@fynla.org

# =============================================================================
# Awin Affiliate Tracking
# =============================================================================
AWIN_ENABLED=true
AWIN_MERCHANT_ID=126105
AWIN_COOKIE_DOMAIN=fynla.org
AWIN_HTTP_TIMEOUT_SECONDS=3

# Frontend (Vite) — required so the MasterTag and browser pixel load.
VITE_AWIN_ENABLED=true
VITE_AWIN_MERCHANT_ID=126105
VITE_AWIN_MASTER_TAG_URL=https://www.dwin1.com/126105.js
VITE_AWIN_FALLBACK_PIXEL=https://www.awin1.com/sread.img
