APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

# Asset URL for subfolder deployment (production only)
# For local development, leave this commented out
# For production at https://csjones.co/fps, set to: https://csjones.co/fps
# ASSET_URL=

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1
ALLOWED_ORIGINS=http://localhost:8000
FRONTEND_URL=http://localhost:8000

VITE_APP_NAME="${APP_NAME}"

# API Base URL for frontend (leave empty for local dev, set for production)
# Local: leave commented out (will use http://127.0.0.1:8000)
# Production: set to your domain (e.g., https://csjones.co/fps)
# VITE_API_BASE_URL=

# Revolut Payment Integration
REVOLUT_API_KEY=
REVOLUT_PUBLIC_KEY=
REVOLUT_WEBHOOK_SECRET=
REVOLUT_SANDBOX=true
VITE_REVOLUT_PUBLIC_KEY=${REVOLUT_PUBLIC_KEY}
VITE_REVOLUT_SANDBOX=${REVOLUT_SANDBOX}
PAYMENT_ENABLED=false

# Analytics (Plausible Cloud - privacy-first, no cookies, GDPR-compliant)
ANALYTICS_ENABLED=false
PLAUSIBLE_DOMAIN=

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Plausible Analytics (frontend)
VITE_PLAUSIBLE_DOMAIN=

# AI Provider: 'anthropic' or 'xai'
AI_PROVIDER=anthropic

# Anthropic (legacy)
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_ADVANCED_CHAT_MODEL=claude-sonnet-4-6-20260320

# xAI Grok
XAI_API_KEY=
XAI_CHAT_MODEL=grok-4-1-fast-reasoning
XAI_ADVANCED_CHAT_MODEL=grok-4-1-fast-reasoning
XAI_VISION_MODEL=grok-4-1-fast-non-reasoning
XAI_BASE_URL=https://api.x.ai/v1

AGENT_INTERNAL_TOKEN=

# Push Notifications (Firebase Cloud Messaging)
FCM_PROJECT_ID=
FCM_PRIVATE_KEY=
FCM_CLIENT_EMAIL=
